# ── LLM providers (priority: OpenAI → Gemini → Groq) ──────────────────────────
OPENAI_API_KEY=        # platform.openai.com — GPT-4o-mini, ~$0.12 for full dataset (recommended)
GEMINI_API_KEY=        # aistudio.google.com — Gemini 2.0 Flash, free tier
GROQ_API_KEY=          # console.groq.com — Llama 3.3 70B, free but low TPM

# ── Data ingestion ──────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ── Storage ─────────────────────────────────────────────────────────────────────
DB_URL=sqlite:///data/reviews.db
DATA_DIR=data
CHROMA_DIR=data/chroma

# ── App ─────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
